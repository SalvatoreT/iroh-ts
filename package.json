{
  "name": "@salvatoret/iroh",
  "version": "0.1.0",
  "description": "TypeScript bindings for iroh, the modular networking stack",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/SalvatoreT/iroh-ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "main": "./dist/node.js",
  "types": "./dist/node.d.ts",
  "exports": {
    ".": {
      "node": {
        "import": "./dist/node.js",
        "types": "./dist/node.d.ts"
      },
      "browser": {
        "import": "./dist/browser.js",
        "types": "./dist/browser.d.ts"
      },
      "default": {
        "import": "./dist/browser.js",
        "types": "./dist/browser.d.ts"
      }
    }
  },
  "files": [
    "dist",
    "crate/pkg"
  ],
  "scripts": {
    "build:wasm:node": "CC=${CC:-clang} AR=${AR:-ar} wasm-pack build crate --target nodejs --out-dir pkg/nodejs",
    "build:wasm:browser": "CC=${CC:-clang} AR=${AR:-ar} wasm-pack build crate --target bundler --out-dir pkg/bundler",
    "build:wasm": "pnpm build:wasm:node && pnpm build:wasm:browser",
    "build:ts": "tsc",
    "build": "pnpm build:wasm && pnpm build:ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
